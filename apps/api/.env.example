APP_NAME=Patch Manager API
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://patchmanager:patchmanager@localhost:5432/patchmanager
JWT_SECRET=changeme
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_FULL_NAME=Patch Manager Admin
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
SCHEDULER_AUTOSTART=true
SCHEDULER_INTERVAL_SECONDS=300
WORKER_AUTOSTART=true
WORKER_INTERVAL_SECONDS=30
AGENT_BOOTSTRAP_TOKEN=patch-manager-bootstrap-token
SEED_LINUX_AGENT_ID=linux-agent-01
SEED_LINUX_AGENT_KEY=patch-manager-agent-key
SEED_LINUX_AGENT_DESCRIPTION=Linux agent default credential
