APP_NAME=Patch Manager API
APP_ENV=production
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://patchmanager:change-me-postgres@db:5432/patchmanager
JWT_SECRET=change-me-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-admin
SEED_ADMIN_FULL_NAME=Patch Manager Admin
SEED_ADMIN_ROLE=admin
SEED_ADMIN_FORCE_PASSWORD_CHANGE=true
CORS_ALLOW_ORIGINS=https://localhost,https://127.0.0.1
CORS_ALLOW_ORIGIN_REGEX=
SCHEDULER_AUTOSTART=true
SCHEDULER_INTERVAL_SECONDS=300
WORKER_AUTOSTART=true
WORKER_INTERVAL_SECONDS=30
AGENT_BOOTSTRAP_TOKEN=change-me-bootstrap
SEED_LINUX_AGENT_ID=linux-agent-01
SEED_LINUX_AGENT_KEY=change-me-agent
SEED_LINUX_AGENT_DESCRIPTION=Linux agent default credential
